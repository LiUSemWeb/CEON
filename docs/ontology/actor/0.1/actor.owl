  <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="http://w3id.org/CEON/ontology/actor/0.1/"/>
    <owl:imports rdf:resource="http://w3id.org/CEON/ontology/actorODP/0.1/"/>
    <dcterms:contributor>Huanyu Li</dcterms:contributor>
    <dcterms:contributor>Mikael Lindecrantz</dcterms:contributor>
    <dcterms:contributor>Robin Keskisärkkä</dcterms:contributor>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2023-03-16</dcterms:created>
    <dcterms:creator>Eva Blomqvist</dcterms:creator>
    <dcterms:description>The Actor module of CEON (Circular Economy Ontology Network).</dcterms:description>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/LiUSemWeb/CEON/blob/master/LICENSE</dcterms:license>
    <dcterms:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Circular Economy Ontology Network (CEON) - Actor Module</dcterms:title>
    <vann:preferredNamespacePrefix rdf:datatype="http://www.w3.org/2001/XMLSchema#string">actor</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri rdf:datatype="http://www.w3.org/2001/XMLSchema#string">http://w3id.org/CEON/ontology/actor/</vann:preferredNamespaceUri>
    <odp:coversRequirements>In addition to requirements covered by imported ODPs, covers the following requirements from Onto-DESIDE D3.1: C0-1, C0-2, C3-4, T3-4</odp:coversRequirements>
    <rdfs:seeAlso rdf:resource="https://github.com/LiUSemWeb/CEON"/>
    <owl:versionInfo>0.1</owl:versionInfo>
  </rdf:Description>
