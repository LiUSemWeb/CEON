  <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/ProcessParticipation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
    <rdfs:subClassOf rdf:nodeID="nfee1a0a965f3492ba576ddcb6f8e15cdb25"/>
    <rdfs:comment>Participation of a certain actor in a certain process, with a certain role. For instance, a certain department of a recycling company having the role of quality controllant, or material sorter, in a certain recycling process. The participation may also be given a time, e.g. a start and end time.</rdfs:comment>
    <rdfs:label>Process Participation</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actorODP/participatingResource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
