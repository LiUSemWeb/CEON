  <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/CVNParticipation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://w3id.org/CEON/ontology/actorODP/CollaborationParticipation"/>
    <rdfs:subClassOf rdf:nodeID="nfee1a0a965f3492ba576ddcb6f8e15cdb5"/>
    <rdfs:comment>A participation-relation, that represents the participation of an actor in a CVN with a certain role. For instance, a specific company playing the role of recycler in a certain flow of a CVN. The participation may also be related to a certain time (or time interval).</rdfs:comment>
    <rdfs:label>Circular Value Network Participation</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://w3id.org/CEON/ontology/actor/reseller">
