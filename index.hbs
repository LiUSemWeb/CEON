      <tr><th>Source Ontology</th><th></th><th>Target Ontology</th><th>Alignment</th></tr>
    </thead>
    <tbody>
      {{#each alignment_data.logistics}}
      <tr>
        <td><a href="{{source_uri}}">{{source}}</a></td>
        <td class="align-arrow text-center">&#8594;</td>
        <td><a href="{{target_uri}}">{{target}}</a></td>
        <td>
          <a class="badge-format badge-rdf" href="alignment/logistics/{{name}}.rdf">rdf</a>
          <a class="badge-format badge-ttl" href="alignment/logistics/{{name}}.ttl">ttl</a>
          <a class="badge-format badge-tsv" href="alignment/logistics/{{name}}.tsv">tsv</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- General -->
  <h3 class="subsection-title">General (Top) level ontologies</h3>
  <table class="table table-striped table-bordered table-hover">
    <thead>
      <tr><th>Source Ontology</th><th></th><th>Target Ontology</th><th>Alignment</th></tr>
    </thead>
    <tbody>
      {{#each alignment_data.general}}
      <tr>
        <td><a href="{{source_uri}}">{{source}}</a></td>
        <td class="align-arrow text-center">&#8594;</td>
        <td><a href="{{target_uri}}">{{target}}</a></td>
        <td>
          <a class="badge-format badge-rdf" href="alignment/general/{{name}}.rdf">rdf</a>
          <a class="badge-format badge-ttl" href="alignment/general/{{name}}.ttl">ttl</a>
          <a class="badge-format badge-tsv" href="alignment/general/{{name}}.tsv">tsv</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

