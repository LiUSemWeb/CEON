  <h3 class="subsection-title">Actor</h3>
  <div class="table-responsive-wrapper"><table class="table table-striped table-bordered table-hover">
    <thead>
      <tr><th>Ontology</th><th>Version</th><th>Serializations</th><th>Docs</th><th>License</th></tr>
    </thead>
    <tbody>
      {{#each data.actor}}
      <tr>
        <td><a class="onto-name" href="ontology/{{name}}/{{versions.0}}/index.html">{{name}}</a></td>
        <td><span class="label-version">{{versions.0}}</span></td>
        <td>
          <a class="badge-format badge-ttl" href="ontology/{{name}}/{{versions.0}}/{{name}}.ttl">ttl</a>
          <a class="badge-format badge-rdf" href="ontology/{{name}}/{{versions.0}}/{{name}}.rdf">rdf</a>
          <a class="badge-format badge-json" href="ontology/{{name}}/{{versions.0}}/{{name}}.jsonld">json-ld</a>
        </td>
        <td>
          <a class="badge-format badge-html" href="ontology/{{name}}/{{versions.0}}/index.html">html</a>
          <a class="badge-format badge-pdf" href="ontology/{{name}}/{{versions.0}}/{{name}}.pdf">pdf</a>
        </td>
        <td><a class="badge-license" href="https://creativecommons.org/licenses/by/4.0/" target="_blank">CC-BY 4.0</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table></div>

