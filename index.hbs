    .navbar .navbar-header { display: flex; align-items: center; height: 60px; }
    .navbar-brand { display: flex !important; align-items: center; height: 60px !important; padding-top: 0 !important; padding-bottom: 0 !important; color: #ecf0f1 !important; font-size: 1.3em; }
    .navbar-brand img { display: block; }
    .navbar-nav > li > a { color: #ecf0f1 !important; line-height: 60px; padding-top: 0; padding-bottom: 0; font-size: 1em; }
    .navbar-nav > li > a:hover { color: #1abc9c !important; background: transparent !important; }
    .navbar-toggle { margin-top: 13px; }

    .page-header { border-bottom: 2px solid #1abc9c; margin-bottom: 25px; }
    .page-header h1 { color: #2c3e50; font-weight: 300; font-size: 2.4em; }

    .intro-text { color: #555; font-size: 1.1em; margin-bottom: 20px; line-height: 1.7; }

    .overview-img { text-align: center; margin: 25px 0; }
    .overview-img img { max-width: 100%; border: 1px solid #ddd; border-radius: 4px; padding: 8px; background: #fff; }

    h2.section-title {
      font-size: 1.6em;
      color: #2c3e50;
      font-weight: 600;
      margin-top: 30px;
      margin-bottom: 12px;
      padding-bottom: 6px;
      border-bottom: 1px solid #e0e0e0;
    }
    h3.subsection-title {
      font-size: 1.2em;
      color: #555;
      font-weight: 600;
      margin-top: 22px;
      margin-bottom: 10px;
    }

    .table { font-size: 1em; }
    .table > thead > tr > th {
      background-color: #2c3e50;
      color: #ecf0f1;
      border-color: #2c3e50;
      font-weight: 500;
      white-space: nowrap;
      font-size: 1em;
    }
    .table-striped > tbody > tr:nth-of-type(odd) { background-color: #f9f9f9; }
    .table > tbody > tr > td { vertical-align: middle; }
    .table > tbody > tr:hover { background-color: #eaf7f4; }

    .badge-format {
      display: inline-block;
      padding: 3px 8px;
      font-size: 0.85em;
      font-weight: 600;
      border-radius: 3px;
      margin-right: 3px;
      text-decoration: none;
      color: #fff;
    }
    .badge-ttl  { background-color: #27ae60; }
    .badge-rdf  { background-color: #e74c3c; }
    .badge-json { background-color: #f39c12; }
    .badge-html { background-color: #2980b9; }
    .badge-pdf  { background-color: #8e44ad; }
    .badge-tsv  { background-color: #16a085; }

    .badge-format:hover { opacity: 0.85; color: #fff; text-decoration: none; }

    .label-version {
      display: inline-block;
      background: #ecf0f1;
      color: #2c3e50;
      border: 1px solid #bdc3c7;
      padding: 2px 9px;
      border-radius: 10px;
      font-size: 0.88em;
      font-weight: 600;
    }

    .onto-name { font-weight: 600; color: #2c3e50; font-size: 1em; }
    .onto-name:hover { color: #1abc9c; }

    .section-desc { color: #666; font-size: 1em; margin-bottom: 15px; }

